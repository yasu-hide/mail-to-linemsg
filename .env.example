# PostgreSQL connection string.
DATABASE_URL=<REPLACE_WITH_DATABASE_URL>

# LINE Login channel settings.
LINECORP_PLATFORM_LOGIN_CHANNEL_ID=<REPLACE_WITH_LINE_LOGIN_CHANNEL_ID>
LINECORP_PLATFORM_LOGIN_CHANNEL_SECRET=<REPLACE_WITH_LINE_LOGIN_CHANNEL_SECRET>
LINECORP_PLATFORM_LOGIN_CHANNEL_CALLBACKURL=<REPLACE_WITH_LINE_LOGIN_CALLBACK_URL>

# Express session signing secret.
SESSION_SECRET=<REPLACE_WITH_SESSION_SECRET>

# Optional. CSRF token signing secret. Falls back to SESSION_SECRET if unset.
# Recommended to set an independent random value for key separation.
#CSRF_SECRET=<REPLACE_WITH_CSRF_SECRET>

# LINE Messaging API channel settings.
LINECORP_PLATFORM_MESSAGING_CHANNEL_ACCESSTOKEN=<REPLACE_WITH_LINE_MESSAGING_CHANNEL_ACCESS_TOKEN>
LINECORP_PLATFORM_MESSAGING_CHANNEL_SECRET=<REPLACE_WITH_LINE_MESSAGING_CHANNEL_SECRET>

# Public key used to verify inbound parse webhook signatures.
INBOUND_PARSE_WEBHOOK_PUBLIC_KEY=<REPLACE_WITH_INBOUND_PARSE_WEBHOOK_PUBLIC_KEY>
