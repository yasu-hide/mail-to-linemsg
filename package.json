    "debug": "^4.4.3",
    "dicer": "^0.2.5",
    "dotenv": "^8.6.0",
    "ejs": "^3.1.10",
    "email-addresses": "^5.0.0",
    "express": "^4.22.1",
    "express-session": "^1.18.2",
    "helmet": "^4.6.0",
    "html-to-text": "^9.0.5",
    "iconv": "^3.0.1",
